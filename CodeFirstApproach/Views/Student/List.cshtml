@model IEnumerable<CodeFirstApproach.Models.Student>

@{
    ViewData["Title"] = "Students List";
}

<!-- Include Google Fonts and Font Awesome -->
<link rel="stylesheet" href="https://cloudflare.com" />
<link href="https://googleapis.com" rel="stylesheet">

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f4f7f6;
    }
    /* পুরো কন্টেইনারকে স্ক্রিনের মাঝখানে রাখার জন্য wrapper */
    .center-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 15px;
    }
    /* ছোট এবং সুনির্দিষ্ট সাইজের কন্টেইনার */
    .compact-container {
        width: 100%;
        max-width: 850px; /* কন্টেইনার ছোট রাখার জন্য */
    }
    .gradient-header {
        background: linear-gradient(135deg, #004642 0%, #00796b 100%);
    }
    /* ছোট অ্যাকশন বাটন */
    .action-btn {
        transition: all 0.2s ease-in-out;
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }
    .action-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.12);
    }
    /* আধুনিক রো (Row) স্টাইল কার্ড */
    .student-row-card {
        border: none;
        border-radius: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
        background-color: #ffffff;
    }
    .student-row-card:hover {
        transform: translateX(4px); /* ডানদিকে সামান্য সরবে */
        box-shadow: 0 6px 15px rgba(0,0,0,0.05) !important;
    }
    .avatar-circle {
        width: 40px;
        height: 40px;
        background-color: #e0f2f1;
        color: #00796b;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.95rem;
    }
    .fs-7 {
        font-size: 0.85rem !important;
    }
    .info-item {
        font-size: 0.85rem;
        color: #6c757d;
    }
</style>

<div class="center-wrapper">
    <div class="compact-container">
        
        <!-- Header Section -->
        <div class="gradient-header p-4 rounded-3 shadow-sm text-white mb-4">
            <div class="row align-items-center">
                <div class="col-sm-8 text-center text-sm-start">
                    <span class="badge bg-white bg-opacity-25 text-white mb-1 px-2 py-1 rounded-pill text-uppercase fs-7 fw-semibold">Workspace</span>
                    <h1 class="h3 fw-bold mb-1">🎓 Student Management</h1>
                    <p class="text-white-50 fs-7 mb-0">Browse and maintain active student records cleanly.</p>
                </div>
                <div class="col-sm-4 text-center text-sm-end mt-3 mt-sm-0">
                    <a asp-action="Create" class="btn btn-light btn-sm rounded-pill shadow-sm fw-bold px-3 py-2 text-success border-0">
                        <i class="fas fa-plus-circle me-1 text-success"></i>Add Student
                    </a>
                </div>
            </div>
        </div>

        <!-- Student List in Row Style -->
        <div class="d-flex flex-column gap-2">
            @foreach (var student in Model)
            {
                <div class="card student-row-card shadow-sm">
                    <div class="card-body p-3">
                        <div class="row align-items-center text-center text-md-start">
                            
                            <!-- Avatar & Profile (Name/ID) -->
                            <div class="col-md-4 d-flex align-items-center justify-content-center justify-content-md-start mb-2 mb-md-0">
                                <div class="avatar-circle shadow-sm text-uppercase me-3 d-none d-sm-flex">
                                    @(string.IsNullOrEmpty(student.Name) ? "?" : student.Name.Substring(0, 1))
                                </div>
                                <div class="overflow-hidden">
                                    <h6 class="mb-0 fw-bold text-dark text-truncate">@student.Name</h6>
                                    <small class="text-muted fs-7"><i class="fa-solid fa-id-badge me-1"></i> ID: @student.ID</small>
                                </div>
                            </div>

                            <!-- Contact Info (Email & Phone) -->
                            <div class="col-md-5 mb-3 mb-md-0">
                                <div class="row">
                                    <div class="col-sm-6 info-item text-truncate mb-1 mb-sm-0">
                                        <i class="fa-solid fa-envelope text-muted me-1" style="width: 15px;"></i>
                                        <span>@student.Email</span>
                                    </div>
                                    <div class="col-sm-6 info-item mb-1 mb-sm-0">
                                        <i class="fa-solid fa-phone text-muted me-1" style="width: 15px;"></i>
                                        <span>@student.Phone</span>
                                    </div>
                                </div>
                                <div class="info-item mt-1 d-none d-md-block">
                                    <i class="fa-solid fa-cake-candles text-muted me-1" style="width: 15px;"></i>
                                    <span>@student.Dob.ToString("MMM dd, yyyy")</span>
                                </div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="col-md-3 d-flex justify-content-center justify-content-md-end gap-2">
                                <a asp-action="Details" asp-route-id="@student.ID" 
                                   class="btn btn-outline-info action-btn rounded-circle" 
                                   title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@student.ID" 
                                   class="btn btn-outline-warning action-btn rounded-circle" 
                                   title="Edit Profile">
                                    <i class="fas fa-pencil-alt"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@student.ID" 
                                   class="btn btn-outline-danger action-btn rounded-circle" 
                                   title="Remove Student">
                                    <i class="fas fa-trash-can"></i>
                                </a>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Navigation Footer -->
        <div class="mt-4 text-center">
            <a asp-controller="Student" asp-action="Index" class="btn btn-outline-dark btn-sm rounded-pill px-3 py-1.5 shadow-sm text-uppercase fs-7 fw-bold">
                <i class="fas fa-arrow-left me-1"></i>Back
            </a>
        </div>
        
    </div>
</div>
