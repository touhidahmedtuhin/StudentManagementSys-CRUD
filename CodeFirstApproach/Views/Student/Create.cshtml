@model CodeFirstApproach.Models.Student

@{
    ViewData["Title"] = "Create Student";
}

<!-- Include Google Fonts and Font Awesome -->
<link rel="stylesheet" href="https://cloudflare.com" />
<link href="https://googleapis.com" rel="stylesheet">

<style>
    body {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #f4f7f6;
    }

    .create-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px 15px;
    }
    /* 🚀 কন্টেইনার ছোট করার জন্য max-width কমিয়ে 420px করা হয়েছে */
    .create-card {
        border: none;
        border-radius: 12px;
        background-color: #ffffff;
        width: 100%;
        max-width: 420px;
    }

    .gradient-header {
        background: linear-gradient(135deg, #004642 0%, #00796b 100%);
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }
    /* ইনপুট বক্স ও আইকনের সাইজ ছোট (sm) করা হয়েছে */
    .input-group-text {
        background-color: #e0f2f1;
        color: #00796b;
        border: 1px solid #ced4da;
        font-size: 0.85rem;
    }

    .form-control {
        font-size: 0.85rem;
        padding: 0.4rem 0.75rem;
    }

        .form-control:focus {
            border-color: #00796b;
            box-shadow: 0 0 0 0.2rem rgba(0, 121, 107, 0.15);
        }

    .fs-7 {
        font-size: 0.8rem !important;
    }
</style>

<div class="create-wrapper">
    <div class="card create-card shadow-sm">

        <!-- ডার্ক গ্রিন থিমড হেডার (প্যাডিং কমানো হয়েছে) -->
        <div class="gradient-header p-3 text-white text-center">
            <h5 class="fw-bold mb-0">
                <i class="fas fa-user-plus me-1"></i>Add New Student
            </h5>
            <p class="text-white-50 fs-7 mb-0">Fill in details to register profile</p>
        </div>

        <!-- কার্ড বডির প্যাডিং p-4 থেকে কমিয়ে p-3 করা হয়েছে -->
        <div class="card-body p-3">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2 small"></div>

                <!-- নাম ফিল্ড -->
                <div class="mb-2">
                    <label asp-for="Name" class="form-label fw-bold text-dark fs-7 mb-1"></label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="fas fa-user"></i></span>
                        <input asp-for="Name" class="form-control" placeholder="Enter full name" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger fs-7"></span>
                </div>

                <!-- জন্মতারিখ ফিল্ড -->
                <div class="mb-2">
                    <label asp-for="Dob" class="form-label fw-bold text-dark fs-7 mb-1">Date of Birth</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                        <input asp-for="Dob" class="form-control" type="date" />
                    </div>
                    <span asp-validation-for="Dob" class="text-danger fs-7"></span>
                </div>

                <!-- ইমেইল ফিল্ড -->
                <div class="mb-2">
                    <label asp-for="Email" class="form-label fw-bold text-dark fs-7 mb-1"></label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger fs-7"></span>
                </div>

                <!-- ফোন নম্বর ফিল্ড -->
                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-bold text-dark fs-7 mb-1"></label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="fas fa-phone"></i></span>
                        <input asp-for="Phone" class="form-control" placeholder="01XXXXXXXXX" />
                    </div>
                    <span asp-validation-for="Phone" class="text-danger fs-7"></span>
                </div>

                <!-- বোতাম বা অ্যাকশন বার (প্যাডিং ও সাইজ ছোট করা হয়েছে) -->
                <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                    <a asp-action="List" class="btn btn-outline-secondary btn-xs rounded-pill px-2.5 py-1 fs-7 fw-bold">
                        <i class="fas fa-arrow-left me-1"></i> Back
                    </a>

                    <button type="submit" class="btn text-white btn-xs rounded-pill px-3 py-1 fs-7 fw-bold shadow-sm" style="background-color: #004642;">
                        <i class="fas fa-save me-1"></i> Save
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
