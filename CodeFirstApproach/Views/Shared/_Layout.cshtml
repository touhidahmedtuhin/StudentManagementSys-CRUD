<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] -AKSC</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CodeFirstApproach.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark shadow fixed-top" style="background-color: #004642;">
            <div class="container">
                <!-- Brand with small logo -->
                <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
                    <img src="/images/AkSchool.png" alt="Logo" width="170" height="50" class="me-2">
                </a>

                <!-- Toggler for mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navbar Links -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-2"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Student" asp-action="Index">
                                <i class="fas fa-user-graduate me-2"></i> Students
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="About">
                                <i class="fas fa-info-circle me-2"></i> About
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-warning fw-bold" asp-controller="Home" asp-action="Contact">
                                <i class="fas fa-envelope me-2"></i> Contact
                            </a>
                        </li>
                    </ul>
                </div>
    </header>
            <!-- Main Wrapper -->
            <div class="d-flex flex-column min-vh-100">
                <!-- Content Area -->
                <main class="flex-fill">
                    @RenderBody()
                </main>

                <!-- Footer -->
                <footer class="text-white py-4 shadow" style="background-color: #004642; margin-top:40px;">
                    <div class="container d-flex justify-content-between align-items-center flex-wrap">
                        <!-- Left Side Text -->
                        <div style="color: #FFD700;">
                            <p class="mb-1 fw-bold">
                                <i class="fas fa-school me-2"></i> AK School & College
                            </p>
                            <p class="mb-1">
                                <i class="fas fa-map-marker-alt me-2"></i> Mirpur-1, Dhaka, Bangladesh
                            </p>
                            <p class="mb-0">
                                <i class="fas fa-copyright me-2"></i>
                                @DateTime.Now.Year AK School & College. All rights reserved.
                            </p>
                        </div>

                        <!-- Right Side Logo + Social Icons -->
                        <div class="text-end">
                            <img src="/images/AkSchool.png" alt="Logo" width="140" height="50" class="rounded shadow-sm mb-2">

                            <!-- Social Media Icons -->
                            <div >
                                <a href="https://facebook.com" target="_blank" class="social-icon mx-2">
                                    <i class="fab fa-facebook fa-lg"></i>
                                </a>
                                <a href="https://twitter.com" target="_blank" class="social-icon mx-2">
                                    <i class="fab fa-twitter fa-lg"></i>
                                </a>
                                <a href="https://linkedin.com" target="_blank" class="social-icon mx-2">
                                    <i class="fab fa-linkedin fa-lg"></i>
                                </a>
                                <a href="https://instagram.com" target="_blank" class="social-icon mx-2">
                                    <i class="fab fa-instagram fa-lg"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </footer>


            </div>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
