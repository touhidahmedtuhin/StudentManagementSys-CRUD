@{
    ViewData["Title"] = "Home";
}
<!-- About Section -->
<!-- Include Google Fonts and Font Awesome -->
<link rel="stylesheet" href="https://cloudflare.com" />
<link href="https://googleapis.com" rel="stylesheet">

<style>
    .about-section {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: linear-gradient(135deg, #ffffff 0%, #f4f7f6 100%);
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
    }

    .school-title {
        color: #004642;
        position: relative;
        display: inline-block;
        padding-bottom: 10px;
    }
        /* টাইটেলের নিচে সুন্দর একটি আন্ডারলাইন */
        .school-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 3px;
            background-color: #00796b;
            border-radius: 2px;
        }
    /* বৈশিষ্ট্য কার্ডগুলোর স্টাইল */
    .feature-card {
        background: #ffffff;
        border: none;
        border-radius: 12px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .feature-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05) !important;
        }
    /* আইকনের গোল ব্যাকগ্রাউন্ড */
    .icon-wrapper {
        width: 60px;
        height: 60px;
        background-color: #e0f2f1;
        color: #00796b;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin: 0 auto 15px;
    }
</style>

<style>
    .about-section {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background: linear-gradient(135deg, #ffffff 0%, #f4f7f6 100%);
        box-shadow: 0 2px 15px rgba(0, 0, 0, 0.03);
        border-radius: 0px;
    }

    .school-title {
        color: #004642;
        position: relative;
        display: inline-block;
        padding-bottom: 6px;
    }

        .school-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 3px;
            background-color: #00796b;
            border-radius: 2px;
        }
</style>

<!-- 🚀 পরিবর্তন: margin-top বাড়িয়ে 120px করা হয়েছে যাতে এটি আরও নিচে নেমে আসে -->
<section class="text-center about-section py-3 px-4 w-100" style="margin-top: 120px; overflow: hidden;">
    <div class="container-fluid">

        <!-- প্রধান আইকন -->
        <div class="mb-1 text-muted" style="font-size: 1.5rem;">
            <i class="fa-solid fa-school text-success opacity-75"></i>
        </div>

        <!-- স্কুল নাম -->
        <h3 class="fw-bold school-title mb-2 fs-4">AK School & College</h3>

        <!-- বিবরণী -->
        <p class="text-secondary mt-2 mx-auto mb-0" style="max-width: 650px; font-size: 0.95rem; line-height: 1.5;">
            We provide modern education facilities with a focus on holistic growth, building tomorrow's leaders today.
        </p>

    </div>
</section>



<!-- About Section End -->
<!-- Controls Start-->
<div id="schoolCarousel" class="carousel slide shadow" data-bs-ride="carousel" style="margin-top:70px;">
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="/images/akschool_banner.png" class="d-block w-100 carousel-img" alt="School Campus">
            <div class="carousel-caption d-none d-md-block">
                <h5>Beautiful Campus</h5>
                <p>Experience a green and friendly environment.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="/images/classroom.jpg" class="d-block w-100 carousel-img" alt="School Campus">
            <div class="carousel-caption d-none d-md-block">
                <h5>Beautiful Campus</h5>
                <p>Experience a green and friendly environment.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="/images/library.jpg" class="d-block w-100 carousel-img" alt="Classroom">
            <div class="carousel-caption d-none d-md-block">
                <h5>Modern Classrooms</h5>
                <p>Interactive learning with modern facilities.</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="/images/hallroom.jpg" class="d-block w-100 carousel-img" alt="Library">
            <div class="carousel-caption d-none d-md-block">
                <h5>Library</h5>
                <p>Access to thousands of books and resources.</p>
            </div>
        </div>
    </div>


    <button class="carousel-control-prev" type="button" data-bs-target="#schoolCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#schoolCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>
<!-- Controls End-->
<!-- Feature section start -->
<section class="mt-5">
    <div class="container text-center">
        <h2 class="fw-bold fst-italic" style="color: #004642;">Our Features</h2>

        <div class="row mt-4">
            <!-- Card 1 -->
            <div class="col-md-4">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-chalkboard-teacher fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Modern Classrooms</h5>
                        <p class="card-text">Interactive learning with digital facilities and more.</p>
                    </div>
                </div>
            </div>

            <!-- Card 2 -->
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-book-open fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Rich Library</h5>
                        <p class="card-text">Thousands of books and resources available.</p>
                    </div>
                </div>
            </div>

            <!-- Card 3 -->
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-tree fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Beautiful Campus</h5>
                        <p class="card-text">Green and friendly environment for students.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!--Feature section start-->
<!-- Gallery Section -->
<section class="mt-5">
    <div class="container text-center">
        <h2 class="fw-bold fst-italic" style="color: #004642;">Our Gallery</h2>

        <div class="row mt-4">
            <!-- Gallery Item 1 -->
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 feature-card">
                    <img src="/images/classroom.jpg" class="card-img-top rounded" alt="Classroom">
                    <div class="card-body">
                        <h5 class="card-title text-success">
                            <i class="fas fa-chalkboard fa-lg me-2"></i> Modern Classroom
                        </h5>
                        <p class="card-text">Smart boards and digital learning facilities.</p>
                    </div>
                </div>
            </div>

            <!-- Gallery Item 2 -->
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 feature-card">
                    <img src="/images/library.jpg" class="card-img-top rounded" alt="Library">
                    <div class="card-body">
                        <h5 class="card-title text-success">
                            <i class="fas fa-book fa-lg me-2"></i> Rich Library
                        </h5>
                        <p class="card-text">Thousands of books and resources available.</p>
                    </div>
                </div>
            </div>

            <!-- Gallery Item 3 -->
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 feature-card">
                    <img src="/images/hallroom.jpg" class="card-img-top rounded" alt="Campus">
                    <div class="card-body">
                        <h5 class="card-title text-success">
                            <i class="fas fa-tree fa-lg me-2"></i> Beautiful Campus
                        </h5>
                        <p class="card-text">Green and friendly environment for students.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Gallery Section -->
<!-- Notice Board Section -->
<section class="mt-5">
    <div class="container text-center">
        <h2 class="fw-bold fst-italic" style="color: #004642;">Notice Board</h2>

        <div class="row mt-4">
            <!-- Notice 1 -->
            <div class="col-md-4">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-bullhorn fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Admission Open</h5>
                        <p class="card-text">Applications are now open for the new academic session.</p>
                    </div>
                </div>
            </div>

            <!-- Notice 2 -->
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-calendar-alt fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Exam Schedule</h5>
                        <p class="card-text">Final exams will start from 25th June 2026.</p>
                    </div>
                </div>
            </div>

            <!-- Notice 3 -->
            <div class="col-md-4 mt-3 mt-md-0">
                <div class="card shadow h-100 feature-card">
                    <div class="card-body">
                        <div class="text-center mb-3">
                            <i class="fas fa-users fa-3x text-success"></i>
                        </div>
                        <h5 class="card-title text-success">Parent Meeting</h5>
                        <p class="card-text">Annual parent-teacher meeting scheduled for next month.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- Notice Board Section -->




